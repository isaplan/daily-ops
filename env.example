# MongoDB (Local)
MONGODB_URI=mongodb://localhost:27017/daily-ops
MONGODB_DB_NAME=daily-ops

# Shared secret for scheduled HTTP hooks (GET /api/inbox/watch/renew?secret=..., Bork/Eitje run-scheduled)
CRON_SECRET=

# App
PORT=8080

# Slack OAuth (Optional for POC)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Eitje API
# Note: Eitje credentials are stored in MongoDB (api_credentials collection)
# You need to create a document with:
# {
#   provider: 'eitje',
#   isActive: true,
#   baseUrl: 'https://open-api.eitje.app/open_api', // or your custom URL
#   additionalConfig: {
#     partner_username: 'your-partner-username',
#     partner_password: 'your-partner-password',
#     api_username: 'your-api-username',
#     api_password: 'your-api-password'
#   }
# }
# 
# The system will automatically use the active Eitje credentials from MongoDB.
# No environment variables needed for Eitje credentials.

# Bork API (sales / POS)
# Bork credentials are stored in MongoDB (api_credentials collection).
# Create a document with:
# {
#   provider: 'bork',
#   isActive: true,
#   baseUrl: 'https://YOUR-GATEWAY.trivecgateway.com',
#   apiKey: 'your-appid-api-key',
#   locationId: ObjectId('...')  // optional; required for sync if not passed in request body
# }
# Or use config: { baseUrl, apiKey } instead of top-level baseUrl/apiKey.
# No environment variables needed for Bork credentials.

# Bork V2 rebuild from existing raw (optional; see scripts/rebuild-bork-v2-date-range.ts)
# BORK_V2_REBUILD_CONFIRM=1
# BORK_V2_START=2026-02-01
# BORK_V2_END=2026-04-18
# BORK_AGG_V2_SUFFIX=

# Gmail API (OAuth2)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_REDIRECT_URI=http://localhost:8080
GMAIL_INBOX_ADDRESS=inboxhaagsenieuwehorecagroep@gmail.com

# Gmail Push Notifications (Pub/Sub)
# Format: projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC_NAME
# Example: projects/daily-ops-123456/topics/gmail-inbox-notifications
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC_NAME
# Inbox webhook logic: server/services/inboxWebhookService.ts (POST /api/inbox/webhook)
# Optional: OIDC / shared-secret verification can be added in front of Nitro (see dev-docs/GMAIL_PUBSUB_SETUP.md)
