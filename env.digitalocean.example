# Copy variables below into DigitalOcean App → Settings → App-Level Environment Variables.
# Replace placeholders with real values. Do not commit secrets — use .env.digitalocean.local (gitignored) locally.
#
# GitHub repository secrets (workflows: daily-ops-sync.yml, gmail-watch-renew.yml; inbox-daily-sync.yml is manual-only — Gmail poll runs on DO via Nitro once daily ~10:00 Amsterdam CEST):
#   DO_APP_DOMAIN=your-app.ondigitalocean.app   (hostname only, no https://) — used if CRON_API_BASE_URL unset
#   CRON_API_BASE_URL=https://<web-service-default-ingress>.ondigitalocean.app   (full URL to the Node/Nitro service)
#     Required when your public domain serves SPA HTML for /api/* (static). Use DO’s Web Service URL so cron hits Nitro.
#   CRON_SECRET=same value as CRON_SECRET below
#
# Google Cloud OAuth client → Authorized redirect URIs must include the exact GMAIL_REDIRECT_URI you use here.

MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?appName=daily-ops
MONGODB_DB_NAME=daily-ops

CRON_SECRET=generate-a-long-random-string

# Cron-only inbox (recommended on DO): skip Gmail users.watch on boot — GitHub inbox-daily-sync.yml polls instead.
GMAIL_AUTO_WATCH_ON_START=0

# --- Gmail API (OAuth2) — production on DigitalOcean ---
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
# Must match Authorized redirect URI used when this refresh token was created (exact string).
# On DigitalOcean use your HTTPS app URL (or exact callback path), NOT http://localhost — localhost here causes invalid_grant on refresh in production.
# If you minted the token via OAuth Playground, use: https://developers.google.com/oauthplayground
# Local dev only: http://localhost:8080 (or :8081)
# Example production:
GMAIL_REDIRECT_URI=https://daily-opps-cjoxp.ondigitalocean.app
GMAIL_INBOX_ADDRESS=inboxhaagsenieuwehorecagroep@gmail.com

# Gmail Push (Pub/Sub) — format projects/PROJECT_ID/topics/TOPIC_NAME
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC_NAME

# Optional cap for GitHub / manual inbox sync (GET maxResults)
# INBOX_SYNC_MAX_RESULTS=100

# Bork/Eitje: Nitro scheduled task + optional startup catch-up (see nuxt.config.ts, server/plugins/integration-sync-catchup.ts)
# DISABLE_INTEGRATIONS_SCHEDULED=1
# INTEGRATION_SYNC_CATCHUP_ON_START=0   # default on in NODE_ENV=production; set 0 to skip boot-time stale check
# INTEGRATION_SYNC_STALE_MS=32400000    # optional override (ms); default 9h if unset

# --- After custom domain (daily-ops.team) is live ---
# 1. Add https://daily-ops.team (and https://www.daily-ops.team if needed) to Authorized redirect URIs.
# 2. Re-authorize Gmail if you switch issuance host; then set e.g.:
# GMAIL_REDIRECT_URI=https://daily-ops.team
