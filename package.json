{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev -p 8080",
    "dev:clean": "lsof -ti:8080 | xargs kill -9 2>/dev/null; rm -rf .nuxt .output node_modules/.vite node_modules/.cache && nuxt prepare && nuxt dev -p 8080",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "copy:locations-teams": "node --experimental-strip-types scripts/copy-locations-teams-to-remote.ts",
    "copy:unified-users": "node --experimental-strip-types scripts/copy-unified-users-to-remote.ts",
    "migrate:credentials": "node --experimental-strip-types scripts/migrate-credentials-to-remote.ts",
    "bork:backfill": "NODE_OPTIONS='--max-old-space-size=8192' node --experimental-strip-types scripts/bork-full-raw-backfill.ts",
    "bork:rebuild:aggregates": "node --experimental-strip-types scripts/rebuild-bork-v1-date-range.ts",
    "bork:validate:v2-vs-csv": "node --experimental-strip-types scripts/generate-day-breakdown-v2-vs-csv-tables.ts --write",
    "bork:rebuild:v2": "npx --yes tsx scripts/rebuild-bork-v2-date-range.ts",
    "eitje:backfill": "npx --yes tsx scripts/eitje-full-raw-backfill.ts",
    "eitje:rebuild:labor": "npx --yes tsx scripts/rebuild-eitje-labor-aggregation.ts",
    "eitje:rebuild:labor:all": "npx --yes tsx scripts/rebuild-eitje-labor-aggregation.ts all",
    "eitje:backfill:labor-loaded": "npx --yes tsx scripts/rebuild-eitje-labor-aggregation.ts all --snapshots",
    "eitje:ensure-agg-index": "npx --yes tsx scripts/ensure-eitje-agg-unique-index.ts",
    "eitje:repair-labor-day": "npx --yes tsx scripts/repair-labor-day.ts",
    "inbox:remap-eitje-hours": "npx --yes tsx scripts/remap-inbox-eitje-hours-from-parseddatas.ts",
    "backfill:cron-priority": "npx --yes tsx scripts/backfill-cron-priority.ts",
    "backfill:cron-priority-eitje-hours": "npx --yes tsx scripts/backfill-cron-priority-eitje-hours.ts",
    "backfill:eitje-hours-from-parseddatas": "npx --yes tsx scripts/backfill-eitje-hours-from-parseddatas.ts",
    "members:backfill-unified-user-id": "npx --yes tsx scripts/backfill-members-unified-user-id.ts",
    "snapshots:backfill": "npx --yes tsx scripts/backfill-revenue-snapshot-sections.ts",
    "snapshots:backfill:order-time": "npx --yes tsx scripts/backfill-revenue-by-order-time-snapshots.ts",
    "snapshots:backfill:dry-run": "npx --yes tsx scripts/backfill-revenue-snapshot-sections.ts -- --dry-run",
    "bundles:pregen": "npx --yes tsx scripts/pregenerate-dashboard-bundles.ts",
    "bundles:pregen:7d": "npx --yes tsx scripts/pregenerate-dashboard-bundles.ts --days 7",
    "bundles:pregen:30d": "npx --yes tsx scripts/pregenerate-dashboard-bundles.ts --days 30",
    "snapshots:backfill:infected": "npx --yes tsx scripts/backfill-infected-revenue-snapshots.ts",
    "snapshots:backfill:infected:dry-run": "npx --yes tsx scripts/backfill-infected-revenue-snapshots.ts -- --dry-run",
    "snapshots:backfill:daily-ops": "npx --yes tsx scripts/backfill-daily-ops-full-snapshots.ts",
    "snapshots:backfill:daily-ops:all": "npx --yes tsx scripts/backfill-daily-ops-full-snapshots.ts -- --all-locations",
    "snapshots:backfill:daily-ops:dry-run": "npx --yes tsx scripts/backfill-daily-ops-full-snapshots.ts -- --dry-run",
    "snapshots:backfill:daily-ops:force": "npx --yes tsx scripts/backfill-daily-ops-full-snapshots.ts -- --force",
    "snapshots:benchmarks:backfill": "npx --yes tsx scripts/backfill-revenue-benchmarks.ts",
    "seed:revenue-daily-benchmark": "npx --yes tsx scripts/seed-revenue-daily-benchmarks.ts",
    "snapshots:benchmarks:backfill:60d": "npx --yes tsx scripts/backfill-revenue-benchmarks.ts -- --days 60",
    "retention:rehydrate-day": "npx --yes tsx scripts/rehydrate-day-from-blob.ts",
    "retention:purge": "npx --yes tsx scripts/run-data-retention-purge.ts",
    "inbox:purge-intraday": "npx --yes tsx scripts/purge-intraday-basis-inbox.ts",
    "inbox:mark-gmail-disconnected": "npx --yes tsx scripts/mark-gmail-disconnected.ts",
    "locations:seed-chart-colors": "npx --yes tsx scripts/seed-location-chart-colors.ts",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@nuxt/ui": "^4.0.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "d3": "^7.9.0",
    "googleapis": "^171.4.0",
    "html2pdf.js": "^0.14.0",
    "mongodb": "^7.0.0",
    "nuxt": "^4.0.0",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "^5.4.624",
    "tailwindcss": "^4.0.0",
    "vue": "latest",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": "22.22.1"
  },
  "devDependencies": {
  }
}
